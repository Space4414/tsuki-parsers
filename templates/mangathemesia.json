{
  "name": "MangaThemesia",
  "version": "1.1",
  "type": "html",
  "mangaList": {
    "endpoint": "/manga/",
    "pagination": "page",
    "pageParam": "page",
    "method": "GET",
    "itemSelector": "div.bs",
    "titleSelector": ".tt",
    "coverSelector": "img.ts-post-image",
    "linkSelector": "a",
    "searchEndpoint": "/",
    "searchParam": "s"
  },
  "mangaDetail": {
    "titleSelector": "h1.entry-title",
    "coverSelector": "div.thumb img",
    "descriptionSelector": "div.entry-content.entry-content-single p"
  },
  "chapterList": {
    "selector": "div.eph-num",
    "titleSelector": "span.chapternum",
    "linkSelector": "a"
  },
  "pageList": {
    "imageSelector": "div#readerarea img"
  },
  "genres": {
    "endpoint": "/manga/",
    "selector": "ul.genre li"
  }
}
