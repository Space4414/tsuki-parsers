{
  "name": "Madara",
  "version": "1.3",
  "type": "html",
  "mangaList": {
    "endpoint": "/wp-admin/admin-ajax.php",
    "pagination": "page",
    "pageParam": "page",
    "method": "POST",
    "action": "madara_load_more",
    "itemSelector": "div.page-item-detail",
    "titleSelector": ".post-title a",
    "coverSelector": ".c-image-hover img",
    "linkSelector": ".post-title a",
    "searchEndpoint": "/?s",
    "searchParam": "s"
  },
  "mangaDetail": {
    "titleSelector": ".post-title h1",
    "coverSelector": ".summary_image img",
    "descriptionSelector": ".description-summary .summary__content"
  },
  "chapterList": {
    "selector": "li.wp-manga-chapter",
    "titleSelector": "a",
    "linkSelector": "a",
    "action": "manga_get_chapters",
    "endpoint": "/wp-admin/admin-ajax.php"
  },
  "pageList": {
    "imageSelector": ".wp-manga-chapter-img"
  },
  "genres": {
    "endpoint": "/manga-genre/",
    "selector": ".genre-item"
  }
}
